{
  "name": "generator-react-native-vector-icons",
  "version": "13.0.0",
  "description": "Generates React Native vector icons font library",
  "type": "module",
  "files": [
    "generators"
  ],
  "main": "generators/index.js",
  "keywords": [
    "react-native-vector-icons",
    "yeoman-generator"
  ],
  "dependencies": {
    "mem-fs": "^4.1.4",
    "npm-registry-fetch": "^19.1.1",
    "oslllo-svg-fixer": "^6.0.1",
    "postcss": "^8.5.8",
    "postcss-selector-parser": "^7.1.1",
    "registry-auth-token": "^5.1.1",
    "semver": "^7.6.3",
    "yeoman-generator": "^8.1.2"
  },
  "devDependencies": {
    "@types/npm-registry-fetch": "^8.0.9",
    "@types/semver": "^7.7.1",
    "@yeoman/types": "^1.10.3",
    "copyfiles": "^2.4.1",
    "onchange": "^7.1.0",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "prepare": "npm run clean && tsc && npm run copydeps",
    "copydeps": "copyfiles --up 1 'src/*/templates/**' 'src/*/fontforge/**' generators",
    "clean": "rm -rf ./generators",
    "watch": "npm run watch-tsc --silent & npm run watch-deps --silent",
    "watch-deps": "onchange 'src/*/templates/**' 'src/*/fontforge/**' --initial -- pnpm run copydeps",
    "watch-tsc": "tsc -w"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oblador/react-native-vector-icons.git",
    "directory": "packages/generator-react-native-vector-icons"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
