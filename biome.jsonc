{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "includes": [
      "**",
      // pnpm keeps these formatted
      "!**/package.json",
      "!**/packages/**/*/package.json",

      // nx keeps this formatted
      "!**/tsconfig.json",
      "!**/packages/**/*/tsconfig.json",
      "!nx.json",

      // claude keeps these formatted
      "!.claude/settings.local.json",

      // Files auto generated by us
      "!**/packages/**/.yo-rc.json",
      "!**/packages/**/*/lib",
      "!**/packages/**/*/glyphmaps",
      "!**/packages/**/*/.fontcustom-manifest.json",
      "!**/packages/**/*/android/build",
      "!**/.nx",

      // Templates that have ejs
      "!**/packages/generator-react-native-vector-icons/generators",
      "!**/packages/fontawesome-common/generators/app/templates/src",
      "!**/packages/generator-react-native-vector-icons/src/app/templates",

      // Expo app generated files
      "!**/apps/icon-explorer/.expo",
      "!**/apps/icon-explorer/expo-env.d.ts",
      "!**/apps/icon-explorer/src/data/generated",
      "!**/apps/icon-explorer/src/content/docs/generated",
      "!**/apps/icon-explorer/src/uniwind-types.d.ts",
      "!**/apps/icon-explorer/dist",

      // native files
      "!**/apps/icon-explorer/ios",
      "!**/apps/icon-explorer/android",
      "!**/packages/common/android",
      "!**/packages/common/ios"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 120
  },
  "html": {
    "formatter": {
      "enabled": true
    },
    "experimentalFullSupportEnabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["**/apps/icon-explorer/**"],
      "linter": {
        "rules": {
          "suspicious": {
            // Web element casts ('div' as unknown as ComponentType) are needed for RN web
            "noExplicitAny": "off",
            // Uniwind @variant blocks intentionally redefine CSS custom properties per theme
            "noDuplicateCustomProperties": "off",
            // Markdown segments use array index as key — segments are static per content string
            "noArrayIndexKey": "off"
          },
          "security": {
            // Markdown renderer and +html.tsx use dangerouslySetInnerHTML with trusted bundled content only
            "noDangerouslySetInnerHtml": "off"
          },
          "complexity": {
            "noUselessFragments": "off"
          },
          "style": {
            // Stack-based markdown renderer relies on parser invariants for matching open/close tokens
            "noNonNullAssertion": "off"
          },
          "correctness": {
            // colours is derived from resolvedTheme; including in deps is redundant
            "useExhaustiveDependencies": "off"
          }
        }
      }
    }
  ]
}
