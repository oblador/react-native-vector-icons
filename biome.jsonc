{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": [
      "**",
      // pnpm keeps these formatted
      "!**/package.json",
      "!**/packages/**/*/package.json",

      // nx keeps this formatted
      "!**/tsconfig.json",
      "!**/packages/**/*/tsconfig.json",
      "!nx.json",

      // claude keeps these formatted
      "!.claude/settings.local.json",

      // Files auto generated by us
      "!**/packages/**/.yo-rc.json",
      "!**/packages/**/*/lib",
      "!**/packages/**/*/glyphmaps",
      "!**/packages/**/*/.fontcustom-manifest.json",
      "!**/packages/**/*/android/build",
      "!**/apps/website/src/data/generated",
      "!**/apps/website/src/styles/generated",
      "!**/apps/website/dist",
      "!**/.nx",

      // Templates that have ejs
      "!**/packages/generator-react-native-vector-icons/generators",
      "!**/packages/fontawesome-common/generators/app/templates/src",
      "!**/packages/generator-react-native-vector-icons/src/app/templates/src",

      // Astro
      "!**/apps/website/src/data/generated",
      "!**/apps/website/src/styles/generated",
      "!**/apps/website/dist",
      "!**/apps/website/.astro",

      // Upstream files
      "!**/apps/icon-explorer/src/configs/icomoon.config.json",

      // native files
      "!**/apps/icon-explorer/ios",
      "!**/apps/icon-explorer/android",
      "!**/packages/common/android",
      "!**/packages/common/ios"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 120
  },
  "html": {
    "formatter": {
      "enabled": true
    },
    "experimentalFullSupportEnabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    }
  ]
}
