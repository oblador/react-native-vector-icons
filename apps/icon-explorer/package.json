{
  "name": "icon-explorer",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "generate-registry": "node --experimental-strip-types scripts/generate-icon-registry.mts",
    "generate-glyphmap-index": "node --experimental-strip-types scripts/generate-glyphmap-index.mts",
    "prepare": "pnpm run generate-registry && pnpm run generate-glyphmap-index",
    "start": "pnpm run prepare && expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "pnpm run prepare && expo start --web",
    "generate-llms": "node --experimental-strip-types scripts/generate-llms.mts",
    "build:web": "pnpm run prepare && expo export --platform web && pnpm run generate-llms",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
