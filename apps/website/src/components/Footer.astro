---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-16">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <p class="text-sm text-text-dim">&copy; {year} React Native Vector Icons. MIT Licence.</p>

      <div class="flex items-center gap-3 text-sm text-text-dim">
        <a href="https://github.com/sponsors/oblador" class="hover:text-text-muted transition-colors duration-150">
          Sponsor
        </a>

        <span>&middot;</span>

        <a
          href="https://github.com/oblador/react-native-vector-icons/releases"
          class="hover:text-text-muted transition-colors duration-150"
        >
          Changelog
        </a>

        <span>&middot;</span>

        <a href="/llms.txt" class="hover:text-text-muted transition-colors duration-150"> llms.txt </a>

        <span>&middot;</span>

        <span>Built with Astro</span>
      </div>
    </div>
  </div>
</footer>
